@page "/robot-scenario-runner"
@using MartianRobot.Models
@using MartianRobot.Services
@using global::RobotGrid.Client.Services
@inject NavigationManager NavigationManager

<PageTitle>Robot Scenario Runner</PageTitle>

<div class="container py-4">
    <div class="card border-secondary">
        <div class="card-header">
            <h5 class="mb-0">Specify your own grid and robot instructions</h5>
        </div>

        <div class="card-body">
            <EditForm Model="Model" OnValidSubmit="AnimateScenario">
                <DataAnnotationsValidator />

                <div class="vstack gap-2 mb-3">
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-bold me-2">Grid:</span>

                        <label class="fw-bold mb-0" for="grid-width">Width</label>
                        <InputNumber id="grid-width"
                                     class="form-control form-control-sm w-auto"
                                     style="width: 5rem;"
                                     @bind-Value="Model.GridWidth" />

                        <label class="fw-bold mb-0 ms-2" for="grid-height">Height</label>
                        <InputNumber id="grid-height"
                                     class="form-control form-control-sm w-auto"
                                     style="width: 5rem;"
                                     @bind-Value="Model.GridHeight" />
                    </div>

                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="fw-bold me-2">Start:</span>

                        <label class="fw-bold mb-0" for="start-x">X</label>
                        <InputNumber id="start-x"
                                     class="form-control form-control-sm w-auto"
                                     style="width: 4.5rem;"
                                     @bind-Value="Model.StartX" />

                        <label class="fw-bold mb-0 ms-2" for="start-y">Y</label>
                        <InputNumber id="start-y"
                                     class="form-control form-control-sm w-auto"
                                     style="width: 4.5rem;"
                                     @bind-Value="Model.StartY" />

                        <label class="fw-bold mb-0 ms-2" for="heading">Heading</label>
                        <InputSelect id="heading"
                                     class="form-select form-select-sm w-auto"
                                     style="width: 7rem;"
                                     @bind-Value="Model.Heading">
                            @foreach (var heading in Enum.GetValues<Heading>())
                            {
                                <option value="@heading">@heading</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <label class="fw-bold mb-0" for="instructions">Instructions</label>
                        <InputText id="instructions"
                                   class="form-control form-control-sm text-uppercase flex-grow-1"
                                   style="min-width: 14rem;"
                                   @bind-Value="Model.Instructions" />

                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LoadHeavySample" disabled="@IsAnimating">
                            Load Heavy Sample
                        </button>

                        <button type="submit" class="btn btn-sm btn-primary" disabled="@IsAnimating">
                            @(IsAnimating ? "Animating..." : "Animate")
                        </button>
                    </div>

                    <ValidationMessage For="() => Model.Instructions" />
                    <ValidationSummary />
                </div>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @ErrorMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(GridText))
            {
                <div class="card border-secondary">
                    <div class="card-header bg-dark text-light d-flex justify-content-between align-items-center">
                        <span>Scenario Output</span>
                        <small class="text-body-secondary">`.` empty, `*` visited, `X` lost scent</small>
                    </div>
                    <div class="card-body bg-dark text-info">
                        <pre class="mb-0 font-monospace small">@GridText</pre>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private readonly RobotScenarioFrameGenerator _frameGenerator = new();

    [SupplyParameterFromQuery(Name = "width")]
    private int? WidthQuery { get; set; }

    [SupplyParameterFromQuery(Name = "height")]
    private int? HeightQuery { get; set; }

    [SupplyParameterFromQuery(Name = "startX")]
    private int? StartXQuery { get; set; }

    [SupplyParameterFromQuery(Name = "startY")]
    private int? StartYQuery { get; set; }

    [SupplyParameterFromQuery(Name = "heading")]
    private string? HeadingQuery { get; set; }

    [SupplyParameterFromQuery(Name = "instructions")]
    private string? InstructionsQuery { get; set; }

    [SupplyParameterFromQuery(Name = "autorun")]
    private bool? AutoRunQuery { get; set; }

    private RobotScenarioInput Model { get; } = new()
    {
        GridWidth = 5,
        GridHeight = 3,
        StartX = 1,
        StartY = 1,
        Heading = Heading.East,
        Instructions = "RFRFRFRF"
    };

    private string GridText { get; set; } = "";
    private string? ErrorMessage { get; set; }
    private bool IsAnimating { get; set; }
    private bool _hasAppliedQueryParameters;
    private bool _hasAutoRunFromQuery;

    protected override async Task OnParametersSetAsync()
    {
        ApplyOptionalQueryParameters();

        if (ShouldAutoRunFromQuery())
        {
            _hasAutoRunFromQuery = true;
            await AnimateScenario();
        }
    }

    private void ApplyOptionalQueryParameters()
    {
        if (_hasAppliedQueryParameters)
        {
            return;
        }

        if (WidthQuery.HasValue)
        {
            Model.GridWidth = WidthQuery.Value;
        }

        if (HeightQuery.HasValue)
        {
            Model.GridHeight = HeightQuery.Value;
        }

        if (StartXQuery.HasValue)
        {
            Model.StartX = StartXQuery.Value;
        }

        if (StartYQuery.HasValue)
        {
            Model.StartY = StartYQuery.Value;
        }

        if (!string.IsNullOrWhiteSpace(HeadingQuery))
        {
            if (Enum.TryParse<Heading>(HeadingQuery, ignoreCase: true, out var heading))
            {
                Model.Heading = heading;
            }
            else
            {
                ErrorMessage = $"Invalid heading '{HeadingQuery}'.";
            }
        }

        if (!string.IsNullOrWhiteSpace(InstructionsQuery))
        {
            Model.Instructions = InstructionsQuery;
        }

        _hasAppliedQueryParameters = true;
    }

    private bool ShouldAutoRunFromQuery()
    {
        return !_hasAutoRunFromQuery
            && AutoRunQuery == true
            && WidthQuery.HasValue
            && HeightQuery.HasValue
            && StartXQuery.HasValue
            && StartYQuery.HasValue
            && !string.IsNullOrWhiteSpace(HeadingQuery)
            && !string.IsNullOrWhiteSpace(InstructionsQuery);
    }

    private void LoadHeavySample()
    {
        Model.GridWidth = 50;
        Model.GridHeight = 50;
        Model.StartX = 25;
        Model.StartY = 25;
        Model.Heading = Heading.North;
        Model.Instructions = string.Concat(Enumerable.Repeat("FFRFFRFFRFFR", 8));
        ErrorMessage = null;
    }

    private async Task AnimateScenario()
    {
        ErrorMessage = null;
        GridText = "";
        IsAnimating = true;

        try
        {
            var grid = new Grid(Model.GridWidth, Model.GridHeight);
            var startRobot = new Robot(Model.StartX, Model.StartY, Model.Heading);

            foreach (var frame in _frameGenerator.BuildFrames(
                grid,
                startRobot,
                Model.Instructions))
            {
                GridText = frame.GridText;
                await InvokeAsync(StateHasChanged);
                await Task.Delay(600);
            }
        }
        catch (ArgumentException ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsAnimating = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}