@page "/robotgrid"
@using MartianRobot.Models
@using global::RobotGrid.Client.Models
@using global::RobotGrid.Client.Services

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h3 class="mb-0">RobotGrid</h3>
                <small class="text-body-secondary">@Caption</small>
            </div>

            <span class="badge @(IsAnimating ? "text-bg-warning" : "text-bg-success")">
                @(IsAnimating ? "Animating" : "Ready")
            </span>
        </div>

        <div class="card-body">
            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-primary" @onclick="StartAnimation" disabled="@IsAnimating">
                    Animate All Robots
                </button>
            </div>

            <div class="row g-3">
                @foreach (var scenario in Scenarios)
                {
                    <div class="col-12 col-xl-4">
                        <div class="card border-secondary h-100">
                            <div class="card-header bg-dark text-light">
                                @scenario.Title
                            </div>
                            <div class="card-body bg-dark text-info">
                                <pre class="mb-0 font-monospace small">@scenario.GridText</pre>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Caption { get; set; } = "Martian Robot Scenarios";

    private readonly Grid _grid = new(5, 3);
    private readonly RobotScenarioAnimationService _scenarioAnimationService = new();

    private List<RobotScenarioViewModel> Scenarios { get; } = [];
    private bool IsAnimating;

    protected override void OnInitialized()
    {
        Scenarios.AddRange(_scenarioAnimationService.CreateDefaultScenarios());
        _scenarioAnimationService.ResetScenarios(_grid, Scenarios);
    }

    private async Task StartAnimation()
    {
        IsAnimating = true;

        try
        {
            _scenarioAnimationService.ResetScenarios(_grid, Scenarios);

            foreach (var scenario in Scenarios)
            {
                var frames = _scenarioAnimationService.BuildScenarioFrames(_grid, scenario);

                foreach (var frame in frames)
                {
                    scenario.GridText = frame.GridText;
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(600);
                }
            }
        }
        finally
        {
            IsAnimating = false;
            await InvokeAsync(StateHasChanged);
        }
    }
}
